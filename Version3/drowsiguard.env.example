# DrowsiGuard Version3 local runtime config.
# Copy to drowsiguard.env on the Jetson and restart services after editing.

DROWSIGUARD_DEVICE_ID=JETSON-001
DROWSIGUARD_DEMO_MODE=false
DROWSIGUARD_APP_VERSION=Version3

# Replace this with your WebQuanLi host IP before the demo.
DROWSIGUARD_WS_URL=ws://192.168.2.24:8000/ws/jetson/JETSON-001

# Local dashboard.
DROWSIGUARD_DASHBOARD_PORT=8080
# Keep false unless you intentionally allow the dashboard to restart systemd services.
DROWSIGUARD_DASHBOARD_SERVICE_CONTROL=false

# Manual Jetson/NoMachine GUI testing only.
DROWSIGUARD_LOCAL_GUI=false
DROWSIGUARD_LOCAL_GUI_AUTOSTART_SESSION=false
DROWSIGUARD_LOCAL_GUI_WIDTH=1280

# Hardware feature flags.
DROWSIGUARD_FEATURE_GPS=false
DROWSIGUARD_FEATURE_BUZZER=false
DROWSIGUARD_FEATURE_LED=false
DROWSIGUARD_FEATURE_SPEAKER=false
DROWSIGUARD_FEATURE_OTA=true

# Optional manual path for USB HID RFID keyboard-wedge readers.
# Example after plugging reader: /dev/input/event3
DROWSIGUARD_RFID_DEVICE_PATH=

# Bluetooth speaker for car audio. Example: AA:BB:CC:DD:EE:FF
DROWSIGUARD_BLUETOOTH_SPEAKER_MAC=
DROWSIGUARD_AUDIO_BACKEND=auto

# AI performance knobs for Jetson Nano A02.
DROWSIGUARD_AI_CLASSIFIER_ENABLED=true
DROWSIGUARD_AI_WINDOW_SECONDS=5
DROWSIGUARD_AI_THERMAL_WARN_C=75
DROWSIGUARD_AI_THERMAL_CRITICAL_C=80
DROWSIGUARD_FACE_VERIFY_THRESHOLD=0.82

SECRET_KEY=your_secure_random_secret_key_here
DATABASE_URL=sqlite+aiosqlite:///./data/drowsiness.db
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# eSMS Configuration (thay bằng API Key thật khi deploy)
ESMS_API_KEY=your_esms_api_key_here
ESMS_SECRET_KEY=your_esms_secret_key_here
ESMS_BRANDNAME=Baotintuc
ESMS_SMS_TYPE=2

# Admin mặc định để hệ thống tự tạo khi start lần đầu
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
